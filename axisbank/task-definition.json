{
    "family": "axisbank-task",
    "networkMode": "awsvpc",
    "requiresCompatibilities": ["FARGATE"],
    "cpu": "512",
    "memory": "1024",
    "executionRoleArn": "arn:aws:iam::774118824232:role/ecsTaskExecutionRole",
  
    "containerDefinitions": [
      {
        "name": "axisbank-container",
        "image": "IMAGE_PLACEHOLDER",
        "essential": true,
  
        "portMappings": [
          {
            "containerPort": 8080,
            "protocol": "tcp"
          }
        ],
  
        "logConfiguration": {
          "logDriver": "awslogs",
          "options": {
            "awslogs-group": "/ecs/axisbank-task",
            "awslogs-region": "us-east-1",
            "awslogs-stream-prefix": "ecs"
          }
        }
      }
    ]
  }